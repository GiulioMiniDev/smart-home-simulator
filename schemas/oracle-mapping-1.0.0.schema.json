          "type": "string"
        },
        "causeIds": {
          "items": {
            "type": "string"
          },
          "title": "Causeids",
          "type": "array"
        },
        "residentIds": {
          "items": {
            "type": "string"
          },
          "title": "Residentids",
          "type": "array"
        },
        "activityExecutionIds": {
          "items": {
            "type": "string"
          },
          "title": "Activityexecutionids",
          "type": "array"
        },
        "actionExecutionIds": {
          "items": {
            "type": "string"
          },
          "title": "Actionexecutionids",
          "type": "array"
        }
      },
      "required": [
        "observationId",
        "origin",
        "causeType"
      ],
      "title": "OracleObservationLink",
      "type": "object"
    }
  },
  "$id": "urn:smart-home-simulator:schema:oracle-mapping:1.0.0",
