  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "1.0.0",
      "default": "1.0.0",
      "title": "Schemaversion",
      "type": "string"
    },
    "documentType": {
      "const": "oracle_mapping",
      "default": "oracle_mapping",
      "title": "Documenttype",
      "type": "string"
    },
    "mappingId": {
      "minLength": 1,
      "title": "Mappingid",
      "type": "string"
    },
    "observableLogId": {
      "minLength": 1,
      "title": "Observablelogid",
      "type": "string"
    },
    "sourceTraceId": {
      "minLength": 1,
      "title": "Sourcetraceid",
      "type": "string"
    },
    "sourceTraceSemanticDigest": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Sourcetracesemanticdigest",
      "type": "string"
    },
    "links": {
