  "$id": "urn:smart-home-simulator:schema:execution-trace:1.0.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "const": "1.0.0",
      "default": "1.0.0",
      "title": "Schemaversion",
      "type": "string"
    },
    "documentType": {
      "const": "execution_trace",
      "default": "execution_trace",
      "title": "Documenttype",
      "type": "string"
    },
    "traceId": {
      "minLength": 1,
      "title": "Traceid",
      "type": "string"
    },
    "sourceBundleId": {
      "minLength": 1,
      "title": "Sourcebundleid",
      "type": "string"
    },
    "sourceBundleSha256": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Sourcebundlesha256",
      "type": "string"
    },
    "seed": {
      "title": "Seed",
      "type": "integer"
    },
    "engine": {
      "$ref": "#/$defs/EngineMetadata"
    },
    "startedAt": {
      "format": "date-time",
      "title": "Startedat",
      "type": "string"
    },
    "endedAt": {
      "format": "date-time",
      "title": "Endedat",
      "type": "string"
    },
    "status": {
      "const": "completed",
      "default": "completed",
      "title": "Status",
      "type": "string"
    },
    "activityExecutions": {
      "items": {
        "$ref": "#/$defs/ActivityExecution"
      },
      "title": "Activityexecutions",
      "type": "array"
    },
    "actionExecutions": {
      "items": {
        "$ref": "#/$defs/ActionExecution"
      },
      "title": "Actionexecutions",
      "type": "array"
    },
    "movements": {
      "items": {
        "$ref": "#/$defs/MovementExecution"
      },
      "title": "Movements",
      "type": "array"
    },
    "stateTransitions": {
      "items": {
        "$ref": "#/$defs/StateTransition"
      },
      "title": "Statetransitions",
      "type": "array"
    },
    "resourceEvents": {
      "items": {
        "$ref": "#/$defs/ResourceEvent"
      },
      "title": "Resourceevents",
      "type": "array"
    },
    "runtimeEvents": {
      "items": {
        "$ref": "#/$defs/RuntimeEventExecution"
      },
      "title": "Runtimeevents",
      "type": "array"
    },
    "planDeviations": {
      "items": {
        "$ref": "#/$defs/PlanDeviation"
      },
      "title": "Plandeviations",
      "type": "array"
    },
    "dailySummaries": {
      "items": {
        "$ref": "#/$defs/DailyExecutionSummary"
      },
      "title": "Dailysummaries",
      "type": "array"
    },
    "finalState": {
      "$ref": "#/$defs/FinalWorldState"
    },
    "semanticDigest": {
      "pattern": "^[0-9a-f]{64}$",
      "title": "Semanticdigest",
      "type": "string"
    }
  },
  "required": [
    "traceId",
    "sourceBundleId",
    "sourceBundleSha256",
    "seed",
    "startedAt",
    "endedAt",
    "activityExecutions",
    "actionExecutions",
    "movements",
    "stateTransitions",
    "resourceEvents",
    "runtimeEvents",
    "planDeviations",
    "dailySummaries",
    "finalState",
    "semanticDigest"
  ],
  "title": "Smart Home Authoritative Execution Trace 1.0.0",
  "type": "object"
}
