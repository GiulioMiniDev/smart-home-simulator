{
  "$defs": {
    "CompilationIssue": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "enum": [
            "CANONICAL_PLAN_INVALID",
            "CONTINGENCY_PLAN_INFEASIBLE",
            "CONTINGENCY_TARGET_NOT_SCHEDULED",
            "CROSS_BRANCH_DEPENDENCY",
            "HORIZON_EXCEEDS_SOLVER_RANGE",
            "INPUT_SCENARIO_INVALID",
            "MAIN_PLAN_INFEASIBLE",
            "SOLVER_MODEL_INVALID",
            "SOLVER_NOT_OPTIMAL",
            "TIME_PRECISION_UNREPRESENTABLE"
          ],
          "title": "Code",
          "type": "string"
        },
        "severity": {
          "enum": [
            "error",
            "warning"
          ],
          "title": "Severity",
          "type": "string"
        },
        "stage": {
          "enum": [
            "input",
            "preflight",
            "main_plan",
            "contingency",
            "output"
          ],
          "title": "Stage",
          "type": "string"
        },
        "path": {
          "title": "Path",
          "type": "string"
        },
        "message": {
          "title": "Message",
          "type": "string"
        },
        "details": {
          "additionalProperties": {
            "$ref": "#/$defs/JsonValue"
          },
          "title": "Details",
          "type": "object"
        }
      },
      "required": [
        "code",
        "severity",
        "stage",
        "path",
        "message"
      ],
      "title": "CompilationIssue",
      "type": "object"
    },
    "CompilationSummary": {
      "additionalProperties": false,
      "properties": {
        "scheduledActivityCount": {
          "minimum": 0,
          "title": "Scheduledactivitycount",
          "type": "integer"
        },
        "omittedActivityCount": {
          "minimum": 0,
          "title": "Omittedactivitycount",
          "type": "integer"
        },
        "contingencyCount": {
          "minimum": 0,
          "title": "Contingencycount",
          "type": "integer"
        },
        "contingencyActivityCount": {
          "minimum": 0,
          "title": "Contingencyactivitycount",
          "type": "integer"
        },
        "rescheduledActivityCount": {
          "minimum": 0,
          "title": "Rescheduledactivitycount",
          "type": "integer"
        },
        "errorCount": {
          "minimum": 0,
          "title": "Errorcount",
          "type": "integer"
        },
        "warningCount": {
          "minimum": 0,
          "title": "Warningcount",
          "type": "integer"
        }
      },
      "required": [
        "scheduledActivityCount",
        "omittedActivityCount",
        "contingencyCount",
        "contingencyActivityCount",
        "rescheduledActivityCount",
        "errorCount",
        "warningCount"
      ],
      "title": "CompilationSummary",
      "type": "object"
    },
    "JsonValue": {},
    "ObjectiveValues": {
      "additionalProperties": false,
      "properties": {
        "optionalPriorityScore": {
          "minimum": 0,
          "title": "Optionalpriorityscore",
          "type": "integer"
        },
        "optionalActivityCount": {
          "minimum": 0,
          "title": "Optionalactivitycount",
          "type": "integer"
        },
        "durationDeviationMicroseconds": {
          "minimum": 0,
          "title": "Durationdeviationmicroseconds",
          "type": "integer"
        },
        "temporalDeviationMicroseconds": {
          "minimum": 0,
          "title": "Temporaldeviationmicroseconds",
          "type": "integer"
        },
        "scheduledStartSumMicroseconds": {
          "minimum": 0,
          "title": "Scheduledstartsummicroseconds",
          "type": "integer"
        }
      },
      "required": [
        "optionalPriorityScore",
        "optionalActivityCount",
        "durationDeviationMicroseconds",
        "temporalDeviationMicroseconds",
        "scheduledStartSumMicroseconds"
      ],
      "title": "ObjectiveValues",
      "type": "object"
    }
  },
  "$id": "urn:smart-home-simulator:schema:compilation-report:1.0.0",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "compilerVersion": {
      "const": "1.0.0",
      "default": "1.0.0",
      "title": "Compilerversion",
      "type": "string"
    },
    "success": {
      "title": "Success",
      "type": "boolean"
    },
    "sourceScenarioVersion": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Sourcescenarioversion"
    },
    "sourceScenarioId": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Sourcescenarioid"
    },
    "canonicalPlanSha256": {
      "anyOf": [
        {
          "pattern": "^[0-9a-f]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Canonicalplansha256"
    },
    "solverStatus": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Solverstatus"
    },
    "objectiveValues": {
      "anyOf": [
        {
          "$ref": "#/$defs/ObjectiveValues"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "issues": {
      "items": {
        "$ref": "#/$defs/CompilationIssue"
      },
      "title": "Issues",
      "type": "array"
    },
    "summary": {
      "$ref": "#/$defs/CompilationSummary"
    }
  },
  "required": [
    "success",
    "summary"
  ],
  "title": "Smart Home Compilation Report 1.0.0",
  "type": "object"
}
